{
  "name": "byok-vscode-agent",
  "displayName": "BYOK VS Code Coding Agent",
  "description": "A BYOK-only coding agent for Visual Studio Code.",
  "version": "0.0.1",
  "publisher": "byok-agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dumblepy/BYOK-agent.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension/extension.js",
  "contributes": {
    "configuration": {
      "title": "BYOK Agent",
      "properties": {
        "byokAgent.artifacts.maxTotalBytes": {
          "type": "number",
          "default": 268435456,
          "minimum": 1,
          "description": "会話アーティファクトのExtension全体容量（bytes）。"
        },
        "byokAgent.artifacts.maxThreadBytes": {
          "type": "number",
          "default": 67108864,
          "minimum": 1,
          "description": "1スレッドあたりの会話アーティファクト容量（bytes）。"
        },
        "byokAgent.artifacts.maxArtifactBytes": {
          "type": "number",
          "default": 16777216,
          "minimum": 1,
          "description": "1つの会話アーティファクトの最大容量（bytes）。"
        },
        "byokAgent.artifacts.chunkBytes": {
          "type": "number",
          "default": 1048576,
          "minimum": 1,
          "description": "分割保存時の1チャンクの最大容量（bytes）。"
        },
        "byokAgent.artifacts.retentionDays": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "会話アーティファクトの保持日数。"
        },
        "byokAgent.artifacts.evictionPolicy": {
          "type": "string",
          "enum": [
            "oldest-first"
          ],
          "default": "oldest-first",
          "description": "容量超過時の会話アーティファクト削除方針。"
        }
      }
    },
    "commands": [
      {
        "command": "byokAgent.setApiKey",
        "title": "BYOK Agent: Set API Key"
      },
      {
        "command": "byokAgent.deleteApiKey",
        "title": "BYOK Agent: Delete API Key"
      },
      {
        "command": "byokAgent.manageProviderCredentials",
        "title": "BYOK Agent: Manage Provider Credentials"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "byokAgent",
          "title": "BYOK Agent",
          "icon": "./resources/activity-bar.svg"
        }
      ]
    },
    "views": {
      "byokAgent": [
        {
          "type": "webview",
          "id": "byokAgent.view",
          "name": "Agent"
        }
      ]
    }
  },
  "scripts": {
    "_compile": "pnpm run _compile:extension && pnpm run _bundle:webview",
    "_compile:extension": "tsc -p tsconfig.extension.json --noEmit && node scripts/build-extension.mjs",
    "_bundle:webview": "node scripts/build-webview.mjs",
    "check:webview-security": "pnpm _bundle:webview && node scripts/check-webview-security.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "watch": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .vscode package.json tsconfig.json tsconfig.extension.json tsconfig.webview.json tsconfig.eslint.json eslint.config.mjs vitest.config.ts pnpm-workspace.yaml scripts src tests resources .prettierrc.json",
    "format:check": "prettier --check .vscode package.json tsconfig.json tsconfig.extension.json tsconfig.webview.json tsconfig.eslint.json eslint.config.mjs vitest.config.ts pnpm-workspace.yaml scripts src tests resources .prettierrc.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm check:webview-security",
    "vscode:prepublish": "pnpm _compile",
    "build": "pnpm run _compile && vsce package --no-dependencies"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "ajv": "^8.20.0",
    "preact": "10.29.7",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/vscode": "1.125.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "preact-render-to-string": "^6.7.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
