{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://byok-agent.dev/schemas/model-config.schema.json",
  "title": "BYOK Agent model configuration",
  "$ref": "#/$defs/document",
  "$defs": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providers"],
      "properties": {
        "providers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/provider" }
        },
        "defaultModelId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "vendor", "apiType", "models"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "vendor": { "type": "string", "minLength": 1, "maxLength": 128 },
        "apiKey": {},
        "apiType": { "enum": ["chat-completions", "responses", "messages"] },
        "headers": {
          "type": "object",
          "maxProperties": 32,
          "propertyNames": {
            "pattern": "^[A-Za-z0-9!#$%&'*+.^_`|~-]+$"
          },
          "additionalProperties": {
            "type": "string",
            "maxLength": 8192
          }
        },
        "chatCompletionsProfile": { "$ref": "#/$defs/chatCompletionsProfile" },
        "models": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/model" } }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "url",
        "toolCalling",
        "vision",
        "maxInputTokens",
        "maxOutputTokens"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "minLength": 1,
          "maxLength": 128
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "vendor": { "type": "string", "minLength": 1, "maxLength": 128 },
        "url": { "type": "string", "format": "provider-url" },
        "toolCalling": { "type": "boolean" },
        "streaming": { "type": "boolean" },
        "vision": { "type": "boolean" },
        "reasoning": { "type": "boolean" },
        "reasoningEfforts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["none", "low", "medium", "high", "xhigh"] }
        },
        "thinking": { "type": "boolean" },
        "supportsReasoningEffort": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["none", "low", "medium", "high", "xhigh"] }
        },
        "maxInputTokens": { "type": "integer", "minimum": 1024, "maximum": 10000000 },
        "maxOutputTokens": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "chatCompletionsProfile": { "$ref": "#/$defs/chatCompletionsProfile" },
        "agent": { "$ref": "#/$defs/agent" }
      }
    },
    "chatCompletionsProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "systemRole": { "enum": ["system", "developer"] },
        "maxTokensField": { "enum": ["max_tokens", "max_completion_tokens"] },
        "reasoningField": { "enum": ["none", "reasoning_effort"] },
        "reasoningDeltaField": { "enum": ["none", "reasoning_content", "reasoning"] },
        "streamUsage": { "enum": ["include", "omit"] },
        "parallelToolCalls": { "enum": ["include", "omit", "false"] },
        "toolArguments": { "enum": ["string", "object", "auto"] },
        "toolIndex": { "enum": ["required", "id-fallback"] },
        "legacyFunctionCall": { "enum": ["disabled", "enabled"] },
        "synthesizeToolCallId": { "enum": ["disabled", "enabled"] },
        "allowEofAfterFinish": { "type": "boolean" }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "promptProfile": { "type": "string", "minLength": 1, "maxLength": 64 },
        "contextProfile": { "enum": ["compact", "balanced", "extended"] },
        "toolProfile": { "enum": ["read-only", "workspace", "full"] },
        "maxIterations": { "type": "integer", "minimum": 1, "maximum": 100 },
        "maxToolCalls": { "type": "integer", "minimum": 1, "maximum": 500 },
        "maxConsecutiveFailures": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    }
  }
}
